[
  {
    "intent": "get_agent_details",
    "collection": "agents",
    "query": { "$or": [{"UserName": "{param}"}, {"AgentID": "{param}"}, {"Name": {"$regex": "{param}", "$options": "i"}}] },
    "template": "single"
  },
  {
    "intent": "get_agent_company",
    "collection": "agents",
    "query": { "$or": [{"UserName": "{param}"}, {"Name": {"$regex": "{param}", "$options": "i"}}] },
    "projection": { "Name": 1, "Comp_Name": 1, "UserName": 1 },
    "template": "{Name} works for {Comp_Name}."
  },
  {
    "intent": "get_agents_by_nationality",
    "collection": "agents",
    "query": { "Nationality": {"$regex": "{param}", "$options": "i"} },
    "pagination": true,
    "defaultLimit": 10,
    "template": "list"
  },
  {
    "intent": "get_agents_by_company",
    "collection": "agents",
    "query": { "Comp_Name": {"$regex": "{param}", "$options": "i"} },
    "pagination": true,
    "defaultLimit": 10,
    "template": "list"
  },
  {
    "intent": "get_agent_last_login",
    "collection": "agentlogins",
    "query": { "AGENTID": "{param}" },
    "sort": { "LOGINDATE": -1 },
    "limit": 1,
    "template": "{AGENTID} last logged in on {LOGINDATE}."
  },
  {
    "intent": "get_total_agents",
    "collection": "agents",
    "query": {},
    "count": true,
    "template": "There are {count} agents in total."
  },
  {
    "intent": "get_agents_by_date",
    "collection": "agents",
    "query": { "CreatedDate": {"$gte": "{startDate}", "$lte": "{endDate}"} },
    "pagination": true,
    "defaultLimit": 10,
    "template": "list"
  },
  {
    "intent": "get_recent_logins",
    "collection": "agentlogins",
    "query": {},
    "sort": { "LOGINDATE": -1 },
    "pagination": true,
    "defaultLimit": 10,
    "template": "list"
  },
  {
    "intent": "get_logins_by_date",
    "collection": "agentlogins",
    "query": { "LOGINDATE": {"$gte": "{startDate}", "$lte": "{endDate}"} },
    "sort": { "LOGINDATE": -1 },
    "pagination": true,
    "defaultLimit": 10,
    "template": "list"
  },
  {
    "intent": "get_inactive_agents",
    "collection": "agentlogins",
    "aggregate": [
      { "$group": { "_id": "$AGENTID", "lastLogin": { "$max": "$LOGINDATE" } } },
      { "$match": { "lastLogin": { "$lt": "{dateThreshold}" } } },
      { "$lookup": { "from": "agents", "localField": "_id", "foreignField": "UserName", "as": "agentInfo" } }
    ],
    "template": "list"
  },
  {
    "intent": "get_oldest_company",
    "collection": "agents",
    "query": { "Date_establishment": { "$exists": true, "$ne": null } },
    "sort": { "Date_establishment": 1 },
    "limit": 1,
    "template": "{Comp_Name} was established first on {Date_establishment}."
  },
  {
    "intent": "get_newest_company",
    "collection": "agents",
    "query": { "Date_establishment": { "$exists": true, "$ne": null } },
    "sort": { "Date_establishment": -1 },
    "limit": 1,
    "template": "{Comp_Name} was established most recently on {Date_establishment}."
  },
  {
    "intent": "get_all_companies",
    "collection": "agents",
    "query": {},
    "distinct": "Comp_Name",
    "template": "Found {count} companies: {list}"
  },
  {
    "intent": "get_agents_by_email_domain",
    "collection": "agents",
    "query": { "UserName": {"$regex": "@{param}", "$options": "i"} },
    "pagination": true,
    "defaultLimit": 10,
    "template": "list"
  },
  {
    "intent": "search_agent",
    "collection": "agents",
    "query": { "$or": [
      {"UserName": {"$regex": "{param}", "$options": "i"}},
      {"Name": {"$regex": "{param}", "$options": "i"}},
      {"Comp_Name": {"$regex": "{param}", "$options": "i"}},
      {"AgentID": {"$regex": "{param}", "$options": "i"}}
    ]},
    "pagination": true,
    "defaultLimit": 10,
    "template": "list"
  }
]
