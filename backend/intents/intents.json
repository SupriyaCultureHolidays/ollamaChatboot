  {
    "intent": "count_never_logged_in",
    "collection": "agents",
    "aggregate": [
      { "$lookup": { "from": "agentlogins", "localField": "UserName", "foreignField": "AGENTID", "as": "logins" } },
      { "$match": { "logins": { "$size": 0 } } },
      { "$count": "total" }
