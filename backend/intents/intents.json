    "template": "list"
  },
  {
    "intent": "get_inactive_agents",
    "collection": "agentlogins",
    "aggregate": [
      { "$group": { "_id": "$AGENTID", "lastLogin": { "$max": "$LOGINDATE" } } },
      { "$match": { "lastLogin": { "$lt": "{dateThreshold}" } } },
      { "$lookup": { "from": "agents", "localField": "_id", "foreignField": "UserName", "as": "agentInfo" } },
      { "$unwind": { "path": "$agentInfo", "preserveNullAndEmptyArrays": false } },
      { "$project": { "AGENTID": "$_id", "lastLogin": 1, "Name": "$agentInfo.Name", "Comp_Name": "$agentInfo.Comp_Name" } }
    ],
    "pagination": true,
    "defaultLimit": 10,
    "template": "list"
  },
